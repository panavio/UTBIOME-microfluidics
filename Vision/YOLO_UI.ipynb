# Imports
from ultralytics import YOLO
import gradio as gr
import numpy as np
from PIL import Image

# Load model 
model = YOLO("/content/best.pt")

# Detection function
def detect(image, conf):
    results = model(image, conf=conf)

    annotated = results[0].plot()

    boxes = results[0].boxes
    classes = boxes.cls.cpu().numpy() if boxes is not None else []

    counts = {}
    for c in classes:
        name = model.names[int(c)]
        counts[name] = counts.get(name, 0) + 1

    summary = "\n".join([f"{k}: {v}" for k, v in counts.items()])
    if summary == "":
        summary = "No objects detected"

    # Simple diagnosis logic
    if counts.get("RBC", 0) > 5: # Arbitrary number
        summary += "\n\n Possible hematuria detected"
    else:
        summary += "\n\n No significant RBC detected"

    return annotated, summary

# UI
with gr.Blocks() as demo:
    gr.Markdown("# Real-Time Urine Cell Detection")
    gr.Markdown("Microfluidics + Microscopy + YOLOv8")

    with gr.Row():
        image_input = gr.Image(type="numpy", label="Upload Image")
        output_image = gr.Image(label="Detection Output")

    conf_slider = gr.Slider(0.1, 1.0, value=0.5, label="Confidence Threshold")

    output_text = gr.Textbox(label="Analysis")

    btn = gr.Button("Run Detection")

    btn.click(
        fn=detect,
        inputs=[image_input, conf_slider],
        outputs=[output_image, output_text]
    )

# Launch
demo.launch(share=True)
